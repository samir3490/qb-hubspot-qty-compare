rules_version = '2';

// Firebase project: agrasen-technologies
// Apps: algo-trader, qb-hubspot-qty-compare (QB-HB-Qty)
//
// Deploy:
//   firebase use agrasen-technologies
//   firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── AlgoTrader (paper trading, strategies, orders, settings, Zerodha accounts) ──
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // ── QB ↔ HubSpot quantity compare ──
    match /qtyCompareUsers/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Deny everything else (donor-transparency and legacy collections are not on this project)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
